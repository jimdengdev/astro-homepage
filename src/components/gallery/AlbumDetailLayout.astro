---
import { Comment } from '@components/comment';
import PhotoGrid from '@components/gallery/PhotoGrid';
import HomeSider from '@components/layout/HomeSider.astro';
import { Badge } from '@components/ui/badge';
import Cover from '@components/ui/cover/Cover.astro';
import { CONTENT_PADDING } from '@constants/layout';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import type { GalleryAlbum } from '@lib/config/types';
import { Icon } from 'astro-icon/components';
import { localizedPath, t } from '@/i18n';
import type { Locale } from '@/i18n/types';

interface Props {
  album: GalleryAlbum;
  locale: Locale;
}

const { album, locale } = Astro.props;
const galleryListPath = localizedPath('/gallery', locale);
const title = `${album.title} | ${t(locale, 'gallery.title')} | ${siteConfig.title}`;
const photoCount = album.photos?.length ?? 0;
---

<Layout title={title} description={album.description}>
  <TwoColumnLayout>
    <Cover slot="cover" title={album.title} />
    <HomeSider slot="sider" />
    <div
      class={`bg-gradient-start shadow-box tablet:shadow-none flex flex-col gap-8 overflow-hidden ${CONTENT_PADDING.standard}`}
    >
      {/* Back link */}
      <a
        href={galleryListPath}
        class="flex w-fit items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-600 transition-colors hover:bg-pink-100 hover:text-pink-600 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-pink-900/30 dark:hover:text-pink-400"
      >
        <Icon name="fa6-solid:arrow-left" class="h-3.5 w-3.5" />
        {t(locale, 'gallery.backToList')}
      </a>

      {/* Hero card */}
      <div class="relative overflow-hidden rounded-2xl shadow-card">
        <div class="relative aspect-[21/9] overflow-hidden md:aspect-[16/9]">
          <img
            src={album.cover}
            alt={album.title}
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
        </div>
        <div class="absolute right-0 bottom-0 left-0 p-6 text-white md:p-4">
          <h1 class="mb-2 text-3xl font-bold tracking-wide drop-shadow-md md:text-2xl">{album.title}</h1>
          {album.description && <p class="mb-3 max-w-2xl text-sm text-white/90 drop-shadow">{album.description}</p>}
          <div class="flex flex-wrap items-center gap-4 text-xs text-white/80">
            {album.date && (
              <span class="flex items-center gap-1">
                <Icon name="fa6-solid:calendar-days" class="h-3.5 w-3.5" />
                {album.date}
              </span>
            )}
            {album.location && (
              <span class="flex items-center gap-1">
                <Icon name="fa6-solid:location-dot" class="h-3.5 w-3.5" />
                {album.location}
              </span>
            )}
            <span class="flex items-center gap-1">
              <Icon name="fa6-solid:image" class="h-3.5 w-3.5" />
              {t(locale, 'gallery.photoCount', { count: photoCount })}
            </span>
          </div>
          {album.tags && album.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {album.tags.map((tag: string) => (
                <Badge
                  variant="outline"
                  className="border-white/30 bg-white/10 text-white hover:bg-white/20"
                >
                  <Icon name="fa6-solid:tags" class="mr-1 h-3 w-3" />
                  {tag}
                </Badge>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* Photos */}
      <PhotoGrid client:load photos={album.photos} />

      {(album.comments ?? true) && <Comment />}
    </div>
  </TwoColumnLayout>
</Layout>
